    "mermaid": "^11.15.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "react-toastify": "^11.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
