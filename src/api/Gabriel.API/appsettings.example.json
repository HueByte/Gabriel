{
  "ConnectionStrings": {
    "Default": "Data Source=gabriel.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Gabriel.API" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
        "Microsoft.AspNetCore.Authentication": "Warning",
        "Microsoft.AspNetCore.Authentication.JwtBearer": "Warning",
        "System": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithThreadId", "WithLogDate" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "FileLog": {
    "Path": "logs/gabriel-{0}.log",
    "FileSizeLimitBytes": 52428800,
    "OutputTemplate": "{Timestamp:MM-dd-yyyy HH:mm:ss.fff zzz} [{Level:u3}] [{ThreadId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:6080" ]
  },
  "Providers": {
    "Grok": {
      "BaseUrl": "https://api.x.ai/v1/",
      "ApiKey": "REPLACE_ME_GROK_API_KEY",
      "TimeoutSeconds": 900,
      "Temperature": 0.85,
      "TopP": 0.9,
      "Models": [
        {
          "Name": "grok-4.3",
          "IsActive": true,
          "ContextWindowTokens": 1000000,
          "InputPricePerMTokens": 1.25,
          "OutputPricePerMTokens": 2.50,
          "CacheReadPricePerMTokens": 0.00,
          "CacheWritePricePerMTokens": 0.00
        },
        {
          "Name": "grok-4.20-0309-reasoning",
          "IsActive": false,
          "ContextWindowTokens": 1000000,
          "InputPricePerMTokens": 1.25,
          "OutputPricePerMTokens": 2.50,
          "CacheReadPricePerMTokens": 0.00,
          "CacheWritePricePerMTokens": 0.00
        },
        {
          "Name": "grok-4.20-0309-non-reasoning",
          "IsActive": false,
          "ContextWindowTokens": 1000000,
          "InputPricePerMTokens": 1.25,
          "OutputPricePerMTokens": 2.50,
          "CacheReadPricePerMTokens": 0.00,
          "CacheWritePricePerMTokens": 0.00
        },
        {
          "Name": "grok-4.20-multi-agent-0309",
          "IsActive": false,
          "ContextWindowTokens": 2000000,
          "InputPricePerMTokens": 1.25,
          "OutputPricePerMTokens": 2.50,
          "CacheReadPricePerMTokens": 0.00,
          "CacheWritePricePerMTokens": 0.00
        }
      ]
    }
  },
  "Agent": {
    "MaxIterations": 8
  },
  "Auth": {
    "RegistrationEnabled": true,
    "Seed": {
      "Enabled": false,
      "UserName": "admin",
      "Email": "admin@gabriel.local",
      "Password": "REPLACE_ME_SEED_USER_PASSWORD"
    }
  },
  "Personality": {
    "Name": "Gabriel"
  },
  "Tools": {
    "Web": {
      "Active": "ddg",
      "Brave": {
        "BaseUrl": "https://api.search.brave.com/res/v1/web/",
        "ApiKey": "REPLACE_ME_BRAVE_API_KEY",
        "TimeoutSeconds": 15
      }
    },
    "Docs": {
      "GitHub": {
        "Owner": "HueByte",
        "Repo": "Gabriel",
        "Branch": "main",
        "DocsPath": "docs",
        "Token": "REPLACE_ME_GITHUB_TOKEN_OR_LEAVE_BLANK",
        "ListCacheMinutes": 5
      }
    }
  },
  "Projects": {
    "Files": {
      "Root": "./projects-data",
      "MaxFileBytes": 26214400
    }
  },
  "AgentTools": {
    "HostRoot": null,
    "MaxPreviewBytes": 10485760,
    "MaxListEntries": 1000,
    "DefaultListEntries": 200,
    "DefaultPreviewLines": 6
  },
  "Jwt": {
    "Issuer": "gabriel",
    "Audience": "gabriel",
    "SigningKey": "REPLACE_ME_AT_LEAST_32_CHARS_FOR_HS256_SIGNING_KEY",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Infisical": {
    "Host": "https://eu.infisical.com",
    "ProjectId": "REPLACE_ME_INFISICAL_PROJECT_ID",
    "Environment": "dev",
    "SecretPath": "/gabriel",
    "ClientId": "REPLACE_ME_INFISICAL_CLIENT_ID",
    "ClientSecret": "REPLACE_ME_INFISICAL_CLIENT_SECRET",
    "TimeoutSeconds": 15
  }
}
