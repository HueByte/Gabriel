# =============================================================================
# Gabriel — environment file template
# =============================================================================
# Copy to .env and fill in the REPLACE_ME values. docker-compose auto-loads
# .env from the project root, both for ${VAR} substitution in compose.yml and
# for passing through to containers via the env_file: directive.
#
# .NET configuration binder maps __ (double underscore) to nested config keys:
#   Providers__Grok__ApiKey  →  Providers:Grok:ApiKey  →  GrokOptions.ApiKey
#
# Anything you put here overrides the matching appsettings.json entry at runtime.
# =============================================================================

# ---- Host-side ports (compose maps these to the container ports) ------------
WEB_PORT=6080
API_PORT=6040

# ---- ASP.NET runtime --------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
# The API listens on this URL inside the container. Leave as-is unless you
# also adjust the Dockerfile EXPOSE / compose port mapping.
ASPNETCORE_URLS=http://+:8080

# ---- Persistence ------------------------------------------------------------
# SQLite path is relative to the container's /app working dir; the /app/data
# volume keeps the DB across container restarts.
ConnectionStrings__Default=Data Source=/app/data/gabriel.db

# ---- CORS -------------------------------------------------------------------
# Origins the API will accept browser requests from. With the nginx reverse
# proxy in front, the browser sees same-origin requests so this is mainly
# relevant when the SPA is hosted elsewhere.
Cors__AllowedOrigins__0=http://localhost:6080

# ---- Chat provider ----------------------------------------------------------
# Each provider lives in its own named section under "Providers" — e.g.
# Providers:Grok in appsettings.json. Env vars map nested keys with `__`,
# so PROVIDERS__GROK__APIKEY here lands on Providers:Grok:ApiKey and is
# bound into GrokOptions via the standard Options pattern.
Providers__Grok__BaseUrl=https://api.x.ai/v1/
Providers__Grok__ApiKey=REPLACE_ME_GROK_API_KEY
Providers__Grok__TimeoutSeconds=900

# ---- Agent loop -------------------------------------------------------------
Agent__MaxIterations=8

# ---- Auth: registration toggle + seed user ----------------------------------
# Flip RegistrationEnabled to false on private deployments where only the
# seeded user should ever exist — /api/auth/register will return 403.
Auth__RegistrationEnabled=true

# Bootstrap user, created idempotently at startup when Auth__Seed__Enabled=true.
# UserName must be unique. Email defaults to UserName when blank (Identity has
# RequireUniqueEmail=true so a valid email is still required either way).
Auth__Seed__Enabled=false
Auth__Seed__UserName=admin
Auth__Seed__Email=admin@gabriel.local
Auth__Seed__Password=REPLACE_ME_SEED_USER_PASSWORD

# ---- Tools — web search -----------------------------------------------------
# "ddg" (default, no key) or "brave" (requires Brave Search API key below).
Tools__Web__Active=ddg
Tools__Web__Brave__ApiKey=REPLACE_ME_BRAVE_API_KEY_OR_LEAVE_BLANK

# ---- Tools — docs lookup ----------------------------------------------------
# Optional GitHub PAT raises the API rate-limit from 60/h to 5000/h.
Tools__Docs__GitHub__Token=REPLACE_ME_GITHUB_TOKEN_OR_LEAVE_BLANK

# ---- JWT --------------------------------------------------------------------
Jwt__Issuer=gabriel
Jwt__Audience=gabriel
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30
# HS256 symmetric key — MUST be >= 32 chars. Generate one with:
#   openssl rand -base64 48
Jwt__SigningKey=REPLACE_ME_AT_LEAST_32_CHARS_FOR_HS256_SIGNING_KEY

# ---- Infisical (optional) ---------------------------------------------------
# Leave ClientSecret blank to skip Infisical entirely — InfisicalOptions.IsConfigured
# returns false and the provider silently no-ops.
Infisical__Host=https://eu.infisical.com
Infisical__ProjectId=REPLACE_ME_INFISICAL_PROJECT_ID
Infisical__Environment=dev
Infisical__SecretPath=/gabriel
Infisical__ClientId=REPLACE_ME_INFISICAL_CLIENT_ID
Infisical__ClientSecret=REPLACE_ME_INFISICAL_CLIENT_SECRET
Infisical__TimeoutSeconds=15
